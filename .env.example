# GuiaSat — environment template. Copy to `.env` (which is git-ignored) and
# fill in locally. NEVER commit a real key.
#
# AI tutor (the persistent chat assistant). The key is read by the BACKEND
# only (server/), never bundled into the browser, so it can't leak via the
# shipped frontend. With no key set, the tutor runs fully offline on its
# seeded answer library — no network calls, no cost.
#
# The same key powers the live mission CONSULTANT (POST /consult in
# server/flash.js, model claude-opus-4-8). With no key set, the consultant
# runs on its offline heuristic engine — the digital twin still drives the
# draft component list and warnings; only the prose advice is local.
#
# Note: no VITE_ prefix on purpose — VITE_-prefixed vars are exposed in the
# client bundle; this one must stay server-side.
ANTHROPIC_API_KEY=

# ── Unified backend (auth, teams, collaboration) ──────────────────────
# Server-only JWT secret. With none set, the server mints an ephemeral
# random secret on boot (tokens reset on restart). Set a stable value in
# production. NEVER VITE_-prefixed.
FORGE_JWT_SECRET=
# Optional overrides: bcrypt cost (default 10) and token TTL (default 12h).
FORGE_BCRYPT_COST=
FORGE_TOKEN_TTL=
# Optional override for the seed/demo account password (default in
# SEED_ACCOUNTS.md). Server-side only.
FORGE_SEED_PASSWORD=

# Optional convenience for the demo login quick-pick: when set, the
# "Contas de demonstração" buttons auto-fill this password. Left empty so
# no credential is shipped in the client bundle; testers type the password
# documented in SEED_ACCOUNTS.md. VITE_ prefix is intentional (public, and
# only used to speed up local demos).
VITE_FORGE_DEMO_PASSWORD=
